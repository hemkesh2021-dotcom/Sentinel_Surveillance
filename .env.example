# Copy this file to .env and fill in your values
# Never commit .env to git

RTSP_URL=rtsp://<user>:<password>@<camera-ip>:554/cam/realmonitor?channel=1&subtype=1
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional — defaults to ~/yolov8n.engine and ~/face_db.pkl
# YOLO_MODEL=/path/to/yolov8n.engine
# FACE_DB_PATH=/path/to/face_db.pkl
# INTRUDER_LOG=/path/to/intruder_log.json
